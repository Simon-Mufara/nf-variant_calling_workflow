// ----------------------
// Parameters
// ----------------------
params {
  fastq     = "data/mutant_{R1,R2}.fastq"
  reference = "data/wildtype.fna"
  outdir    = "./results"
}

// ----------------------
// Process defaults
// ----------------------
process {
  executor = 'local'
  scratch  = true
  cleanup  = true

  // Load native tools for non-container steps (WRAPPED IN A STRING!)
  beforeScript = '''
    module purge
    module load fastqc
    module load bwa
    module load samtools
    module load bcftools
  '''

  // Trimmomatic runs in your Singularity image (no modules inside this step)
  withName: 'TRIMMOMATIC' {
    cpus   = 1
    memory = '5 GB'
    time   = '1h'
    container = 'trimmomatic_user.sif'
    beforeScript = ''
  }

  // Python-only steps (no modules, no containers)
  withName: 'VCF_TO_SQLITE' {
    cpus   = 1
    memory = '1 GB'
    time   = '30m'
    beforeScript = ''
  }

  withName: 'VARIANT_SUMMARIES' {
    cpus   = 1
    memory = '1 GB'
    time   = '30m'
    beforeScript = ''
  }
}

// ----------------------
// Work directory (hidden)
// ----------------------
workDir = "${baseDir}/.work"

// ----------------------
// Profiles
// ----------------------
profiles {
  local { process.executor = 'local' }
  slurm { process.executor = 'slurm'; process.queue = 'Main' }
}

// ----------------------
// Singularity
// ----------------------
singularity {
  enabled    = true
  autoMounts = true
}